generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

enum Role {
  CLIENT
  VENDOR
  ADMIN
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  role          Role           @default(CLIENT)
  bookings      Booking[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
}
model Vendor {
  id              String    @id @default(uuid())
  name            String
  category        String
  tagline         String
  description     String
  avatar          String
  coverImage      String
  startingPrice   Int
  location        String
  featured        Boolean   @default(false)
  joinedDate      String
  
  // Relations
  services        Service[]
  bookings        Booking[]
}

// 3. Service Model
model Service {
  id          String    @id @default(uuid())
  title       String
  description String
  category    String
  price       Int
  image       String
  
  // Back-relation to Vendor
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorId    String
  
  // Back-relation to Booking (The "Missing Bridge" fix)
  bookings    Booking[] 
}


model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model Transaction {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  amount        Float
  status        String   @default("PENDING") // PENDING, COMPLETED, FAILED
  providerRef   String?  // Reference from Intasend/Stripe
  createdAt     DateTime @default(now())
}

model Booking {
  id          String   @id @default(uuid())
  status      String   @default("PENDING")
  eventDate   DateTime
  totalAmount Float    @default(0.0)
  
  client      User     @relation(fields: [clientId], references: [id])
  clientId    String
  
  service     Service  @relation(fields: [serviceId], references: [id])
  serviceId   String

  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  vendorId    String

  // Back-relation to Transaction (The "Missing Bridge" fix)
  transaction Transaction? 
  createdAt   DateTime @default(now())
}